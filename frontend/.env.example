# Frontend Environment Variables - Copy to .env.local and update values

# Backend API URL (Update this with your Render backend URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# WebSocket URL (Should match backend URL)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Production Example:
# NEXT_PUBLIC_BACKEND_URL=https://your-backend-name.onrender.com
# NEXT_PUBLIC_WS_URL=https://your-backend-name.onrender.com